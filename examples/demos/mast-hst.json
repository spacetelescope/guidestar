{
  "wireframe": "mast-hst.html",
  "title": "MAST HST Search",
  "height": "540px",
  "steps": [
    "#input-objects@1800:type-text=M31|Enter a target name",
    "#btn-resolve@1200:click|Resolve the coordinates",
    "#toggle-dtype-all@1000:remove-class=checked|Deselect All data types",
    "#toggle-dtype-spectrum@1000:add-class=checked|Select Spectrum only",
    "#btn-close-banner@800:click",
    "#mast-app@2000:add-class=banner-closed",
    "#btn-search@600:click|Search for observations",
    "#mast-app@400:add-class=results-open|View results table",
    "pause@2000",
    "#row-3@1200:add-class=highlighted|Inspect a dataset row",
    "pause@1500",
    "#row-3@600:remove-class=highlighted",
    "#btn-edit-search@1200:click|Return to the search form",
    "#mast-app@400:remove-class=results-open",
    "pause@1500"
  ],
  "repeat": true
}
