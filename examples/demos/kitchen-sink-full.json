{
  "wireframe": "kitchen-sink.html",
  "title": "Kitchen Sink — All Built-in Actions",
  "steps": [
    "#btn-sidebar@1800:click|Open the sidebar",
    "#sidebar@800:toggle-class=open",
    "#input-search@1500:type-text=pipeline|Search for a pipeline",
    "#select-mode@1200:set-value=batch|Switch to batch mode",
    "#input-count@1200:set-value=50|Set the batch count",
    "#info-1@1500:set-attribute=data-tooltip:Real-time ETL pipeline|Add a tooltip to the info icon",
    "#card-1@1200:highlight|Highlight the first card",
    "#card-1@1000:toggle-class=highlighted",
    "#card-1-tag@1000:set-text=running|Update the card status tag",
    "#status-text@800:set-text=Processing…|^Update the status bar",
    "#status-badge@800:add-class=success",
    "#status-badge@600:set-text=running",
    "#log-last@1200:scroll-into-view|Scroll to the latest log entry",
    "#btn-action@1500:click|Run the batch action",
    {
      "actions": [
        { "target": "#toast", "action": "add-class", "value": "visible" },
        { "target": "#toast", "action": "set-text", "value": "Pipeline started successfully!" }
      ],
      "delay": 1200,
      "caption": "A toast notification appears"
    },
    "pause@2000",
    "#toast@600:remove-class=visible",
    "#card-2-desc@1200:set-text=Batch mode activated — processing 50 items.|Update the card description",
    "#card-2-tag@800:set-text=active",
    "#card-1@1000:toggle-class=highlighted",
    {
      "actions": [
        { "target": "#status-text", "action": "set-text", "value": "Complete" },
        { "target": "#status-badge", "action": "set-text", "value": "done" }
      ],
      "delay": 1000,
      "caption": "^Mark the pipeline as complete"
    },
    "#info-1@1000:remove-attribute=data-tooltip",
    "#sidebar@1200:toggle-class=open|vClose the sidebar",
    "pause@2000"
  ],
  "repeat": true,
  "autoStart": true,
  "height": "420px"
}
